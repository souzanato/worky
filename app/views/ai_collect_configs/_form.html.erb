<%= form_with(model: [@workflow, @ai_collect_config], validate: true) do |f| %>
  <div class="form-check form-switch mb-3">
    <%= f.check_box :active, class: "form-check-input" %>
    <%= f.label :active, class: "form-check-label" %>
  </div>  

  <div class="mb-3">
    <%= f.label :title, class: "form-label" %>
    <%= f.text_field :title, class: "form-control", placeholder: "e.g., Customer Feedback Collector" %>
  </div>

  <div class="mb-3">
    <%= f.label :code, class: "form-label" %>
    <%= f.text_field :code, class: "form-control", placeholder: "e.g., customer_feedback_v1" %>
    <div class="form-text">Unique identifier for this config (lowercase, underscores allowed)</div>
  </div>

  <div class="mb-3">
    <%= f.label :description, class: "form-label" %>
    <%= f.text_area :description, rows: 3, class: "form-control", placeholder: "Brief description of what this AI config does..." %>
  </div>

  <div class="mb-3">
    <%= f.label :ai_model, class: "form-label" %>
    <%= f.collection_select :ai_model, Action.ai_models, :name, :code, {prompt: true}, class: 'form-select' %>
  </div>

  <div class="form-check form-switch mb-3">
    <%= f.check_box :ask_language, class: "form-check-input" %>
    <%= f.label :ask_language, class: "form-check-label" %>
  </div>  

  <div class="mb-3">
    <%= f.label :prompt, class: "form-label" %>
    <div class="d-flex align-items-center gap-2 mb-1">
      <span class="badge bg-info">
        <i class="fa fa-robot"></i> AI Prompt Template
      </span>
      <small class="text-muted">Use variables like {variable_name} for dynamic values</small>
    </div>
    
    <%= f.text_area :prompt, rows: 6, class: "form-control", placeholder: "Enter your AI prompt template here...", style: "display: none;" %>
  
    <div data-controller="monaco"
         data-monaco-initial-value="<%= f.object.prompt %>"
         data-monaco-language-value="markdown"
         data-monaco-height-value="400px"
         data-monaco-hidden-field-id-value="<%= "#{f.object_name}_prompt" %>"
    ></div>
  </div>

  <div class="d-flex gap-2">
    <%= f.submit(@ai_collect_config.persisted? ? t(".update", default: "Update") : t(".create", default: "Create"),
                 class: "btn btn-theme") %>
    <button type="button" class="btn btn-outline-secondary" data-action="modal#hide"><%= t(".cancel", default: "Cancel") %></button>
  </div>
<% end %>