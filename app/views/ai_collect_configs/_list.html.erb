<div id="ai-collect-configs-list-<%= workflow.class.name %>-<%= workflow.id %>">
  <div class="card border-0 mb-4">
    <div class="card-header bg-none p-3 h6 m-0 d-flex align-items-center">
      <i class="fa fa-robot fa-lg me-2 text-gray text-opacity-50"></i>
      AI Collect Configs
      <span class="badge bg-secondary ms-2"><%= workflow.ai_collect_configs.size %></span>

      <%= link_to t(".add_ai_collect_config", default: "Add AI Collect Config"),
                  [:new, workflow, :ai_collect_config],
                  data: { turbo_frame: "modal" },
                  class: "btn btn-sm btn-outline-primary ms-auto" %>
    </div>

    <div class="card-body p-3">
      <% if workflow.ai_collect_configs.any? %>
        <% workflow.ai_collect_configs.each_with_index do |ai_collect_config, idx| %>
          <div class="border rounded p-3 mb-3 bg-light">
            <div class="d-flex align-items-center mb-2">
              <div class="d-flex align-items-center">
                <span class="badge bg-light text-dark border me-2">#<%= idx + 1 %></span>
                <strong><%= ai_collect_config.title %></strong>
                
                <% if ai_collect_config.ai_model.present? %>
                  <span class="badge bg-info ms-2">
                    <i class="fa fa-microchip"></i> <%= ai_collect_config.ai_model %>
                  </span>
                <% end %>
              </div>
              
              <div class="ms-auto d-flex gap-2">
                <%= link_to [:edit, workflow, ai_collect_config],
                            data: { turbo_frame: "modal" },
                            class: "btn btn-sm btn-outline-dark" do %>
                  <i class="fa fa-pen"></i>
                <% end %>

                <%= link_to [workflow, ai_collect_config],
                            data: { turbo_method: :delete, turbo_confirm: "Are you sure?" },
                            class: "btn btn-sm btn-outline-danger" do %>
                  <i class="fa fa-trash"></i>
                <% end %>
              </div>
            </div>

            <% if ai_collect_config.description.present? %>
              <div class="small text-dark text-opacity-75">
                <%= simple_format(ai_collect_config.description) %>
              </div>
            <% end %>
          </div>
        <% end %>
      <% else %>
        <div class="text-muted"><%= t(".no_configs", default: "No AI collect configs yet") %></div>
      <% end %>
    </div>
  </div>
</div>